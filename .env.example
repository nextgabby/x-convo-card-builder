# Server
PORT=3001
SESSION_SECRET=your_secret_here
DATABASE_PATH=./data/cardforge.db

# X OAuth 2.0 (for user auth, tweets, media)
X_CLIENT_ID=your_x_client_id
X_CLIENT_SECRET=your_x_client_secret
X_REDIRECT_URI=http://localhost:5173/auth/callback

# X OAuth 1.0a (for Ads API / Conversation Cards)
# Generate from Developer Portal → Keys and tokens → "Authentication Tokens"
X_API_KEY=your_api_key
X_API_KEY_SECRET=your_api_key_secret
X_ACCESS_TOKEN=your_access_token
X_ACCESS_TOKEN_SECRET=your_access_token_secret

# App
CLIENT_URL=http://localhost:5173
NODE_ENV=development
